# SMTP Ayarları - .env olarak kopyalayıp doldurun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true

# İmza için gönderen bilgileri (signature.txt/html'de kullanılır)
# SENDER_NAME=Mustafa KALKAN
# SENDER_TITLE=Komite Üyesi
# SENDER_PHONE=0538 640 24 04
# SENDER_EMAIL=ornek@email.com
# SENDER_WEBSITE=https://instagram.com/ais.bau
# SENDER_SOCIAL_MEDIA_LABEL=Instagram  (linkte görünecek kısa metin, uzun URL ... ile kesilmesin)
# SENDER_LINKEDIN=https://linkedin.com/in/kullanici
# SENDER_LINKEDIN_LABEL=Profil  (linkte görünecek kısa metin)
# SENDER_ADDRESS=Bahçeşehir Üniversitesi / Beşiktaş
# SENDER_LOGO_URL=https://example.com/ais-logo.png  (opsiyonel, logo harici URL'den)

# Ek dosyalar (opsiyonel) - virgülle ayırın
# ATTACHMENTS=ek1.pdf,ek2.pdf

# CC, BCC, Reply-To (opsiyonel)
# REPLY_TO=yanit@example.com
# CC=cc1@example.com,cc2@example.com
# BCC=bcc@example.com

# Her mail arası bekleme saniyesi (Gmail sınırları için 2-3 önerilir)
# SEND_DELAY=2

# Zamanlama (opsiyonel) - bu saatte gönder
# SEND_AT=2025-02-28 14:30
# SEND_AT=28.02.2025 14:30
# SEND_AT=14:30
